{
  "$schema": "http://json-schema.org",
  "title": "Itajubá Plugins Marketplace",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "owner": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["name"]
    },
    "homepage": { "type": "string", "format": "uri" },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "version": { "type": "string" },
          "author": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "email": { "type": "string" }
            }
          },
          "source": { "type": "string" },
          "category": { "type": "string" }
        },
        "required": ["name", "source"]
      }
    }
  },
  "required": ["name", "version", "plugins"]
}
